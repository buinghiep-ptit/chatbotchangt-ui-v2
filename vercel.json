{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "yarn build",
  "outputDirectory": "dist",
  "redirects": [
    { "source": "/", "destination": "/ai-agent/sdk/", "permanent": false }
  ],
  "rewrites": [
    { "source": "/ai-agent/sdk/assets/:path*", "destination": "/assets/:path*" },
    { "source": "/ai-agent/sdk/favicon.svg", "destination": "/favicon.svg" },
    { "source": "/ai-agent/sdk/icons.svg", "destination": "/icons.svg" },
    { "source": "/ai-agent/sdk", "destination": "/index.html" },
    { "source": "/ai-agent/sdk/", "destination": "/index.html" },
    { "source": "/ai-agent/sdk/:path*", "destination": "/index.html" }
  ]
}
